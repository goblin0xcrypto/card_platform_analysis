# 複製此檔為 .env 後填入真實值
# cp .env.example .env

# EVM 鏈：Etherscan V2 多鏈端點（同一把 key 可用於 Etherscan / Basescan / Arbiscan /
# Polygonscan / Optimistic Etherscan / BSCScan…，用 chainid 切鏈）。ingest_txs.py / tools/explorer.py 使用。
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Solana ── 交易明細 / getTransaction / NFT(mpl_core)指令解析 / DAS 持有快照（走 RPC）
# 並發單筆 getTransaction（免費；批次為付費限定）。ingest_solana_nft.py 使用。
# https://dev.helius.xyz/dashboard/app
HELIUS_API_KEY=

# Solana ── 帳戶級索引查詢（某地址全部轉帳/餘額變化等），Solscan Pro API v2（需付費方案）。
# header token；ingest_solana.py / tools/solscan.py 使用。
# https://solscan.io/user/profile#api_management
SOLANA_API_KEY=

# 可選：用 Claude 解析 docs HTML 找合約段落
ANTHROPIC_API_KEY=

# 資料庫（後續 ingest.py / run_analysis.py 使用）
DATABASE_URL=postgresql://localhost:5432/card_platform_analysis
